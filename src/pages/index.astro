<section class="return-box">
  <h2>Example structured return</h2>
  <p class="muted">
    Example: A lender provides <strong>30,000</strong> and receives
    <strong>35,000</strong> after 4 weeks.
  </p>

  <div class="result">
    <div>
      <span class="label">Principal</span>
      <span id="principal">30,000</span>
    </div>
    <div>
      <span class="label">Repayment</span>
      <span id="repayment">35,000</span>
    </div>
    <div>
      <span class="label">Profit</span>
      <span id="profit"></span>
    </div>
    <div>
      <span class="label">Return</span>
      <span id="returnRate"></span>
    </div>
  </div>

  <p class="note">
    Capital involves risk. Returns depend on agreement terms and borrower performance.
  </p>
</section>

<script>
  const principal = 30000;
  const repayment = 35000;
  const weeks = 4;

  const profit = repayment - principal;
  const simpleReturn = (profit / principal) * 100;

  document.getElementById("profit").innerText =
    profit.toLocaleString();

  document.getElementById("returnRate").innerText =
    simpleReturn.toFixed(2) + "% in " + weeks + " weeks";
</script>
